# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# FIREBASE CONFIGURATION: Enable live cloud sync by configuring your Firebase app secrets.
# Retrieve these credentials from your Firebase Console under Project Settings -> General.
FIREBASE_API_KEY=FIREBASE_API_KEY_PLACEHOLDER
FIREBASE_APP_ID=FIREBASE_APP_ID_PLACEHOLDER
FIREBASE_PROJECT_ID=FIREBASE_PROJECT_ID_PLACEHOLDER
FIREBASE_STORAGE_BUCKET=FIREBASE_STORAGE_BUCKET_PLACEHOLDER
